# Copy to .env and adjust. Every setting in voiceos/config/settings.py
# is overridable with the VOICEOS_ prefix and __ nesting.

# LLM — any OpenAI-compatible endpoint (default: Ollama)
VOICEOS_LLM__BASE_URL=http://localhost:11434/v1
VOICEOS_LLM__MODEL=qwen3:14b

# STT — faster-whisper
VOICEOS_STT__MODEL=small
VOICEOS_STT__DEVICE=auto
VOICEOS_STT__LANGUAGE=en
# Backup STT providers, tried in order if the primary fails (comma/JSON list)
# VOICEOS_STT__FALLBACK=["whisper"]

# TTS — Svara-TTS inference server
VOICEOS_TTS__BASE_URL=http://localhost:8080/v1
VOICEOS_TTS__VOICE=en_female
# Backup TTS providers, tried in order if the primary fails before audio
# VOICEOS_TTS__FALLBACK=["edge"]

# Turn-taking — adaptive endpointing: wait longer after a brief utterance,
# respond faster once the user has clearly said enough
# VOICEOS_VAD__ADAPTIVE_SILENCE=true
# VOICEOS_VAD__MIN_SILENCE_MS=550
# VOICEOS_VAD__MIN_SILENCE_SHORT_MS=1100

# Predictive endpointing — transcribe while the user speaks and close the turn
# early when the partial text looks complete (CPU-heavy: runs a 2nd STT)
# VOICEOS_VAD__PREDICTIVE_ENDPOINTING=true

# Noise handling — require frame energy to clear a rolling noise floor, so
# steady background noise/echo is less likely to false-trigger
# VOICEOS_VAD__ADAPTIVE_NOISE=true

# Backchanneling — short "mm-hmm"/"right" filler while the assistant thinks
# VOICEOS_PIPELINE__BACKCHANNEL=true

# Tool calling — let the model call registered functions before it answers
# VOICEOS_LLM__TOOLS_ENABLED=true

# Backup LLM brains, tried in order if the primary endpoint is unreachable
# VOICEOS_LLM__FALLBACKS=[{"base_url":"https://api.groq.com/openai/v1","model":"qwen/qwen3-32b","api_key":"gsk_..."}]

# Monitoring — read-only metrics dashboard (JSON) at http://host:port
# VOICEOS_MONITORING__ENABLED=true
# VOICEOS_MONITORING__PORT=8081

# Logging
VOICEOS_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# SIP TRUNK + ARI  (real inbound/outbound calls via docker-compose Asterisk)
# Fill these in your local .env (never commit). Leave TRUNK_* blank for the
# local softphone-only test. See docs/TELEPHONY.md "Make a real call".
# ─────────────────────────────────────────────────────────────────────────────
# TRUNK_NAME=trunk
# TRUNK_SERVER=sip.telnyx.com            # your provider's SIP host
# TRUNK_USERNAME=your_trunk_user
# TRUNK_PASSWORD=your_trunk_secret
# TRUNK_DID=+15559876543                 # a number you own -> outbound caller ID
# TRUNK_REGISTER=true                    # false if the trunk uses pure IP auth
# PUBLIC_IP=                             # your public IP for NAT two-way audio
#                                        #   (also forward 10000-10100/udp + 5060/udp)
# ARI credentials the campaign uses to originate outbound calls:
# ARI_USERNAME=ari
# ARI_PASSWORD=change-me-strong
# For outbound_campaign.py (run on the host, posting to the Asterisk container):
# ARI_BASE_URL=http://localhost:8088
# ARI_USER=ari
# ARI_PASSWORD=change-me-strong
