# ============================================================================
# FULLY LOCAL PROFILE — runs entirely on your machine, offline, no cloud/keys.
# Copy the lines you want into .env (which overrides everything). See docs/LOCAL.md.
# Requires: `ollama serve`, faster-whisper (bundled), and Piper + a voice.
# ============================================================================

# --- LLM: local Ollama (OpenAI-compatible endpoint) ---
VOICEOS_LLM__BASE_URL=http://localhost:11434/v1
VOICEOS_LLM__API_KEY=ollama
VOICEOS_LLM__MODEL=qwen2.5:3b
# NOTE: remove any VOICEOS_LLM__REASONING_EFFORT line — not a thinking model.

# --- STT: local faster-whisper (model auto-downloads + caches on first run) ---
VOICEOS_STT__PROVIDER=whisper
VOICEOS_STT__MODEL=small
VOICEOS_STT__DEVICE=cuda
VOICEOS_STT__COMPUTE_TYPE=int8_float16
# CPU instead? -> VOICEOS_STT__DEVICE=cpu and VOICEOS_STT__COMPUTE_TYPE=int8

# --- TTS: local Piper (download a voice from huggingface.co/rhasspy/piper-voices) ---
VOICEOS_TTS__PROVIDER=piper
VOICEOS_TTS__PIPER_MODEL=C:/Users/sathw/piper-voices/hi_IN-priyamvada-medium.onnx
VOICEOS_TTS__PIPER_SAMPLE_RATE=22050

# --- everything else (VAD=Silero, conversation, campaign) stays as-is ---
VOICEOS_LOG_LEVEL=INFO
